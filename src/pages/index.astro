---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import AmbientBackground from "../components/react/AmbientBackground";
import Hero from "../components/react/Hero";
import Work from "../components/astro/Work.astro";
import About from "../components/astro/About.astro";
import Experience from "../components/astro/Experience.astro";
import Services from "../components/astro/Services.astro";
import Contact from "../components/astro/Contact.astro";
import {
  getProfile,
  getProjects,
  getExperiences,
  getServices,
  getSkills,
} from "../lib/queries";
import { useTranslations } from "../i18n/ui";

const lang = Astro.currentLocale ?? "es";
const t = useTranslations(lang);

// Fetch all data from Sanity in parallel
const [profile, projects, experiences, services, skills] = await Promise.all([
  getProfile(lang),
  getProjects(lang),
  getExperiences(lang),
  getServices(lang),
  getSkills(lang),
]);

// Fallback profile values if Sanity is not yet populated
const safeProfile = profile ?? {
  name: "Ricardo J. Parra M.",
  heroTitle: "Crafting digital experiences",
  heroSubtitle:
    "Frontend Developer & UI/UX Designer exploring the intersection of design and technology through liquid interfaces and immersive interactions.",
  role: "Frontend Developer",
  location: "Barquisimeto, Venezuela",
  bio: [],
  image: null,
  contacts: [
    {
      title: "Email",
      link: "mailto:ricardo.prxr16@gmail.com",
      type: "email" as const,
    },
    {
      title: "GitHub",
      link: "https://github.com/ricardojparram",
      type: "github" as const,
    },
    {
      title: "LinkedIn",
      link: "https://linkedin.com/in/ricardojparram/",
      type: "linkedin" as const,
    },
  ],
};

const title = `${safeProfile.name} - ${safeProfile.role}`;
---

<Layout title={title}>
  <!-- Ambient animated background (React Island) -->
  <AmbientBackground />

  <main class="relative grow pt-28 pb-12 px-4 md:px-7 z-10">
    <div class="max-w-6xl mx-auto flex flex-col gap-12 md:gap-20">
      <!-- Hero section -->
      <Hero
        name={safeProfile.name}
        heroTitle={safeProfile.heroTitle}
        heroSubtitle={safeProfile.heroSubtitle}
        badgeText={t.hero.badge}
      />

      <!-- Selected Works / Projects -->
      {projects.length > 0 && <Work projects={projects} lang={lang} />}

      <!-- About Me -->
      <About profile={safeProfile} lang={lang} skills={skills} />

      <!-- Work Experience -->
      {
        experiences.length > 0 && (
          <Experience experiences={experiences} lang={lang} />
        )
      }

      <!-- Services -->
      {services.length > 0 && <Services services={services} lang={lang} />}

      <!-- Contact -->
      <Contact profile={safeProfile} lang={lang} />
    </div>
  </main>
</Layout>
