---
import "../css/style.css";
import Header from "../components/react/Header";
import FooterAstro from "../components/astro/Footer.astro";
import "lenis/dist/lenis.css";
import { useTranslations } from "../i18n/ui";

interface Props {
  title?: string;
}

const lang = Astro.currentLocale ?? "es";
const t = useTranslations(lang);
const { title = "Ricardo Parra - Frontend Developer" } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Contrata a Ricardo Parra para crear tu aplicación web o móvil. +3 años de experiencia en desarrollo web. Especializado en crear aplicaciones únicas."
    />
    <meta
      name="keywords"
      content="Ricardo Parra, ricardojparram, Ricardo J. Parra, desarrollador web, barquisimeto, Lara, desarrollo web iribarren, desarrollo web, programador, programación, rjpm, @ricardojparram, ricardo dev"
    />
    <meta name="author" content="Ricardo Parra" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:url" content="https://ricardojparram.vercel.app/" />
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Ricardo Parra - Desarrollador Web con +3 años de experiencia."
    />
    <meta
      property="og:description"
      content="Contrata a Ricardo Parra para crear tu aplicación web o móvil. +3 años de experiencia en desarrollo web. Especializado en crear aplicaciones únicas."
    />
    <meta
      property="og:image"
      content="https://ricardojparram.vercel.app/profile.webp"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://ricardojparram.vercel.app/" />
    <meta
      name="twitter:title"
      content="Ricardo Parra - Desarrollador Web con +3 años de experiencia."
    />
    <meta
      name="twitter:description"
      content="Contrata a Ricardo Parra para crear tu aplicación web o móvil. +3 años de experiencia en desarrollo web. Especializado en crear aplicaciones únicas."
    />
    <meta
      name="twitter:image"
      content="https://ricardojparram.vercel.app/profile.webp"
    />
    <link rel="icon" type="image/webp" href="/rp-favicon.webp" />
    <link rel="canonical" href="https://ricardojparram.vercel.app/" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col"
    style="background-color: var(--color-background); color: #f1f5f9; overflow-x: hidden;"
  >
    <!-- React Header Island -->
    <Header client:load nav={t.nav} lang={lang} />

    <!-- Page content -->
    <slot />

    <!-- Static Footer -->
    <FooterAstro />

    <!-- Smooth scroll -->
    <script>
      import Lenis from "lenis";

      const lenis = new Lenis({ lerp: 0.08 });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);

      function setupScrollReveal() {
        const revealGroups = Array.from(
          document.querySelectorAll<HTMLElement>("[data-reveal-group]"),
        );

        if (!revealGroups.length) return;

        revealGroups.forEach((group) => {
          const items = Array.from(
            group.querySelectorAll<HTMLElement>("[data-reveal-item]"),
          );

          items.forEach((item, index) => {
            if (!item.style.getPropertyValue("--reveal-index")) {
              item.style.setProperty("--reveal-index", String(index));
            }
          });
        });

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          revealGroups.forEach((group) => group.classList.add("is-revealed"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries, currentObserver) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              entry.target.classList.add("is-revealed");
              currentObserver.unobserve(entry.target);
            });
          },
          {
            threshold: 0.05,
          },
        );

        revealGroups.forEach((group) => observer.observe(group));
      }

      setupScrollReveal();
    </script>
  </body>
</html>
