---
import "../css/style.css";
import Header from "../components/astro/Header.astro";
import FooterAstro from "../components/astro/Footer.astro";
import "lenis/dist/lenis.css";
import { useTranslations } from "../i18n/ui";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
}

const lang = Astro.currentLocale ?? "es";
const t = useTranslations(lang);
const { title = t.seo.title } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, "https://ricardojparram.vercel.app").href;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={t.seo.description} />
    <meta name="keywords" content={t.seo.keywords} />
    <meta name="author" content="Ricardo Parra" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={t.seo.description} />
    <meta
      property="og:image"
      content="https://ricardojparram.vercel.app/profile.webp"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={t.seo.description} />
    <meta
      name="twitter:image"
      content="https://ricardojparram.vercel.app/profile.webp"
    />
    <link rel="icon" type="image/webp" href="/rp-favicon.webp" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href="https://ricardojparram.vercel.app/" />
    <link rel="alternate" hreflang="en" href="https://ricardojparram.vercel.app/en/" />
    <link rel="alternate" hreflang="x-default" href="https://ricardojparram.vercel.app/" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col"
    style="background-color: var(--color-background); color: #f1f5f9; overflow-x: clip;"
  >
    <Header nav={t.nav} lang={lang} />

    <!-- Page content -->
    <slot />

    <!-- Static Footer -->
    <FooterAstro />

    <SpeedInsights />

    <!-- Animations & Smooth scroll -->
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";

      gsap.registerPlugin(ScrollTrigger);

      // Initialize Lenis for smooth scrolling
      const lenis = new Lenis({ lerp: 0.08 });
      
      // Synchronize Lenis scrolling with GSAP's ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);
      
      // Add Lenis's requestAnimationFrame (raf) method to GSAP's ticker
      // This ensures GSAP and Lenis are perfectly synced
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      
      // Turn off lag smoothing in GSAP to prevent jittering when using smooth scrolling
      gsap.ticker.lagSmoothing(0);

      function setupScrollReveal() {
        const revealGroups = Array.from(
          document.querySelectorAll<HTMLElement>("[data-reveal-group]"),
        );

        if (!revealGroups.length) return;

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          const items = document.querySelectorAll<HTMLElement>("[data-reveal-item]");
          gsap.set(items, { autoAlpha: 1 });
          return;
        }

        revealGroups.forEach((group) => {
          const items = Array.from(
            group.querySelectorAll<HTMLElement>("[data-reveal-item]"),
          );
          
          if (!items.length) return;

          // GSAP handles FOUC (visibility: hidden) by using autoAlpha
          gsap.fromTo(items, 
            { autoAlpha: 0, y: 24 },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.8,
              ease: "power2.out",
              stagger: 0.1,
              scrollTrigger: {
                trigger: group,
                start: "top 85%", 
                once: true,
              }
            }
          );
        });
      }

      setupScrollReveal();
    </script>
  </body>
</html>
