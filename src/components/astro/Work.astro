---
import { urlFor } from "../../lib/sanity";
import type { Project } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";
import { commonIconMap } from "../../lib/icon-registry";
import { Image } from "astro:assets";

interface Props {
  projects: Project[];
  lang: string;
}

const { projects, lang } = Astro.props;
const t = useTranslations(lang);

const projectCards = projects.map((project) => ({
  ...project,
  links: [
    project.github
      ? {
          href: project.github,
          label: `GitHub: ${project.title}`,
          Icon: commonIconMap.github,
        }
      : null,
    project.link
      ? {
          href: project.link,
          label: `Live: ${project.title}`,
          Icon: commonIconMap.external,
        }
      : null,
  ].filter(
    (
      link,
    ): link is {
      href: string;
      label: string;
      Icon: typeof commonIconMap.github;
    } => Boolean(link),
  ),
}));

// Mobile projects get full-width (col-span-12), desktop/regular vary
function getColSpan(project: Project, index: number): string {
  if (project.mobile) return "md:col-span-4";
  const patterns = [
    "md:col-span-8",
    "md:col-span-4",
    "md:col-span-5",
    "md:col-span-8",
    "md:col-span-6",
    "md:col-span-6",
  ];
  return patterns[index % patterns.length] ?? "md:col-span-6";
}
---

<section id="work" data-reveal-group>
  <div class="mb-9" data-reveal-item>
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-white">
      {t.work.title}
    </h2>
    <span class="heading-underline"></span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 w-full">
    {
      projectCards.map((project, index) => (
        <div
          class={`${getColSpan(project, index)} group relative rounded-3xl glass-card overflow-hidden h-85 md:h-108 hover:border-primary/40 transition-all duration-500`}
          data-reveal-item
          style={`--reveal-index: ${index + 1};`}
        >
          {/* Background image */}
          {project.img && (
            <Image
              src={urlFor(project.img)
                .width(900)
                .height(600)
                .fit("crop")
                .auto("format")
                .quality(80)
                .url()}
              alt={project.alt}
              width={900}
              height={600}
              sizes="(max-width: 767px) 100vw, (max-width: 1279px) 66vw, 33vw"
              format="webp"
              quality={75}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          )}

          {/* Gradient overlay */}
          <div class="absolute inset-0 bg-linear-to-t from-black/88 via-black/55 to-transparent z-10" />

          {/* Content */}
          <div class="absolute bottom-0 left-0 p-5 md:p-6 z-20 w-full flex flex-col gap-2.5">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-xl md:text-2xl font-semibold text-white">
                {project.title}
              </h3>
              <div class="flex gap-2 shrink-0">
                {project.links.map((link) => {
                  const Icon = link.Icon;

                  return (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noreferrer"
                      class="size-10 rounded-full glass-card flex items-center justify-center text-white hover:border-primary/45 transition-colors"
                      aria-label={link.label}
                    >
                      <Icon class="size-5" aria-hidden="true" />
                    </a>
                  );
                })}
              </div>
            </div>
            <p class="text-zinc-300 text-sm md:text-base max-w-lg leading-relaxed">
              {project.subtitle}
            </p>
            <div class="flex gap-2 mt-1 flex-wrap">
              {project.technologies?.map((tech) => (
                <span class="px-2.5 py-1 rounded-full shadow-lg! glass-card text-xs text-zinc-300">
                  {tech.name}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
