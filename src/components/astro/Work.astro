---
import { urlFor } from "../../lib/sanity";
import type { Project } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";

interface Props {
  projects: Project[];
  lang: string;
}

const { projects, lang } = Astro.props;
const t = useTranslations(lang);

// Mobile projects get full-width (col-span-12), desktop/regular vary
function getColSpan(project: Project, index: number): string {
  if (project.mobile) return "md:col-span-4";
  const patterns = [
    "md:col-span-8",
    "md:col-span-4",
    "md:col-span-5",
    "md:col-span-8",
    "md:col-span-6",
    "md:col-span-6",
  ];
  return patterns[index % patterns.length] ?? "md:col-span-6";
}
---

<section id="work" class="scroll-mt-28">
  <div class="mb-9">
    <h2 class="text-3xl md:text-4xl font-bold text-white">
      {t.work.title}
    </h2>
    <span class="heading-underline"></span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 w-full">
    {
      projects.map((project, index) => (
        <div
          class={`${getColSpan(project, index)} group relative rounded-3xl glass-card overflow-hidden h-85 md:h-108 hover:border-primary/40 transition-all duration-500`}
        >
          {/* Background image */}
          {project.img && (
            <img
              src={urlFor(project.img).width(900).url()}
              alt={project.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          )}

          {/* Gradient overlay */}
          <div class="absolute inset-0 bg-linear-to-t from-black/88 via-black/55 to-transparent z-10" />

          {/* Content */}
          <div class="absolute bottom-0 left-0 p-5 md:p-6 z-20 w-full flex flex-col gap-2.5">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-xl md:text-2xl font-bold text-white">
                {project.title}
              </h3>
              <div class="flex gap-2 shrink-0">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noreferrer"
                    class="size-10 rounded-full bg-black/45 flex items-center justify-center text-white hover:bg-primary/30 hover:border-primary/45 transition-colors border border-white/20"
                    aria-label={`GitHub: ${project.title}`}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="size-5"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                    </svg>
                  </a>
                )}
                {project.link && (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noreferrer"
                    class="size-10 rounded-full bg-black/45 flex items-center justify-center text-white hover:bg-primary/30 hover:border-primary/45 transition-colors border border-white/20"
                    aria-label={`Live: ${project.title}`}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="size-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                    >
                      <path d="M7 7h10v10M7 17L17 7" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
            <p class="text-slate-300 text-sm md:text-base max-w-lg leading-relaxed">
              {project.subtitle}
            </p>
            <div class="flex gap-2 mt-1 flex-wrap">
              {project.technologies?.map((tech) => (
                <span class="px-2.5 py-1 rounded-full bg-black/35 border border-white/10 text-xs text-slate-300">
                  {tech.name}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
