---
interface Props {
  heroTitle: string;
  heroSubtitle: string;
  badgeText: string;
}

const { heroTitle, heroSubtitle, badgeText } = Astro.props;
const titleParts = heroTitle.trim().split(/\s+/);
const headlineLead = titleParts.slice(0, -1).join(" ");
const headlineAccent = titleParts.at(-1) ?? "";
---

<div class="flex flex-col gap-3 md:gap-4 items-start py-2 md:py-4 relative" data-reveal-group>
  <div
    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-xs font-bold uppercase tracking-wider mb-2 text-primary-light"
    data-reveal-item
  >
    <span class="w-2 h-2 rounded-full animate-pulse bg-primary" aria-hidden="true"></span>
    {badgeText}
  </div>

  <h1
    class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-black tracking-tight text-white text-glow leading-[1.08]"
    data-reveal-item
    style="--reveal-index: 1"
  >
    {headlineLead} <br />
    <span class="text-transparent bg-clip-text bg-linear-to-r from-white to-zinc-500">
      {headlineAccent}.
    </span>
  </h1>

  <p
    class="text-sm sm:text-base md:text-lg text-zinc-400 max-w-xl md:max-w-2xl leading-relaxed"
    data-reveal-item
    style="--reveal-index: 2"
  >
    {heroSubtitle}
  </p>
</div>
