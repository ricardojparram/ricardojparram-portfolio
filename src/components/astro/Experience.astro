---
import type { Experience } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";

interface Props {
    experiences: Experience[];
    lang: string;
}

const { experiences, lang } = Astro.props;
const t = useTranslations(lang);

// Active first, then most recent startDate
const sorted = [...experiences].sort((a, b) => {
    if (b.active !== a.active) return Number(b.active) - Number(a.active);
    return (b.startDate ?? "").localeCompare(a.startDate ?? "");
});
---

<section id="experience" class="scroll-mt-28">
    <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
            {t.experience.title}
        </h2>
        <span class="heading-underline"></span>
    </div>

    <div
        class="flex flex-col gap-6 relative
    before:absolute before:inset-0 before:ml-6 before:-translate-x-px
    md:before:mx-auto md:before:translate-x-0
    before:h-full before:w-0.5
    before:bg-gradient-to-b before:from-transparent before:via-white/10 before:to-transparent"
    >
        {
            sorted.map((exp) => (
                <div class="relative flex items-center justify-between md:justify-normal md:even:flex-row-reverse group">
                    {/* Timeline Icon */}
                    <div class="flex items-center justify-center w-12 h-12 rounded-full border border-white/10 glass-card shrink-0 md:order-1 md:group-even:-translate-x-1/2 md:group-odd:translate-x-1/2 z-10 shadow-primary-soft">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="size-5 text-primary"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"
                            />
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"
                            />
                        </svg>
                    </div>

                    {/* Card */}
                    <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] glass-card rounded-3xl p-6 md:p-8 hover:border-white/20 transition-colors">
                        <div class="flex flex-col gap-1 mb-4">
                            <h3 class="text-xl font-bold text-white">
                                {exp.role}
                            </h3>
                            <div class="flex items-center justify-between gap-2">
                                <span class="font-medium text-primary">
                                    {exp.company}
                                </span>
                                {exp.date && (
                                    <span class="text-xs text-slate-500">
                                        {exp.date}
                                    </span>
                                )}
                            </div>
                        </div>
                        {exp.active && (
                            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs font-medium mb-3">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse" />
                                {t.experience.current}
                            </span>
                        )}
                        {exp.info?.length > 0 && (
                            <ul class="flex flex-col gap-1.5 mt-1">
                                {exp.info.map((block: any) => {
                                    const text = block.children
                                        ?.map((c: any) => c.text)
                                        .join("");
                                    return text ? (
                                        <li class="flex items-start gap-2 text-sm text-slate-400 leading-relaxed">
                                            <span class="mt-1.5 size-1.5 rounded-full bg-primary shrink-0" />
                                            {text}
                                        </li>
                                    ) : null;
                                })}
                            </ul>
                        )}
                    </div>
                </div>
            ))
        }
    </div>
</section>
