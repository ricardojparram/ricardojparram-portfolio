---
import type { Profile } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";
import { commonIconMap } from "../../lib/icon-registry";

interface Props {
  profile: Profile;
  lang: string;
}

const { profile, lang } = Astro.props;
const t = useTranslations(lang);

// Find contact links by type
const email = profile.contacts?.find((c) => c.type === "email")?.link;
const github = profile.contacts?.find((c) => c.type === "github")?.link;
const linkedin = profile.contacts?.find((c) => c.type === "linkedin")?.link;
const cv = profile.contacts?.find((c) => c.type === "cv")?.link;

type ContactAction = {
  href: string;
  label: string;
  Icon: typeof commonIconMap.email;
  className: string;
  external: boolean;
};

type SocialAction = {
  href: string;
  label: string;
  Icon: typeof commonIconMap.github;
};

const isPresent = <T,>(value: T | null): value is T => value !== null;

const ctaLinks: ContactAction[] = [
  email
    ? {
        href: email,
        label: t.contact.email,
        Icon: commonIconMap.email,
        className:
          "h-12 px-6 rounded-xl bg-primary text-white text-sm font-semibold transition-all flex items-center justify-center gap-2 shadow-primary-glow hover:opacity-90",
        external: false,
      }
    : null,
  cv
    ? {
        href: cv,
        label: t.contact.cv,
        Icon: commonIconMap.cv,
        className:
          "h-12 px-6 rounded-xl glass-card text-white text-sm font-semibold transition-all border border-white/10 hover:border-white/20 flex items-center justify-center gap-2",
        external: true,
      }
    : null,
].filter(isPresent);

const socialLinks: SocialAction[] = [
  github
    ? {
        href: github,
        label: "GitHub",
        Icon: commonIconMap.github,
      }
    : null,
  linkedin
    ? {
        href: linkedin,
        label: "LinkedIn",
        Icon: commonIconMap.linkedin,
      }
    : null,
].filter(isPresent);
---

<section id="contact" class="scroll-mt-28">
  <div class="py-6 md:py-12 text-center flex flex-col items-center gap-4">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-white">
      {t.contact.title}
    </h2>
    <p class="text-zinc-400 text-base max-w-2xl">
      {t.contact.subtitle}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-3 mt-3 justify-center">
      {
        ctaLinks.map((action) => {
          const Icon = action.Icon;

          return (
            <a
              href={action.href}
              target={action.external ? "_blank" : undefined}
              rel={action.external ? "noreferrer" : undefined}
              class={action.className}
            >
              <Icon class="size-5" aria-hidden="true" />
              {action.label}
            </a>
          );
        })
      }
    </div>

    <!-- Social Links -->
    <div class="flex items-center gap-5 mt-3">
      {
        socialLinks.map((social) => {
          const Icon = social.Icon;

          return (
            <a
              href={social.href}
              target="_blank"
              rel="noreferrer"
              class="text-zinc-400 hover:text-white transition-colors flex items-center gap-2 text-sm font-medium"
            >
              <Icon class="size-6" aria-hidden="true" />
              {social.label}
            </a>
          );
        })
      }
    </div>
  </div>
</section>
