---
interface Props {
  currentLang: string;
  compact?: boolean;
}

const { currentLang, compact = false } = Astro.props;

const containerClass = compact
  ? "flex items-center gap-1 h-8 px-1 rounded-full border border-white/12 bg-linear-to-br from-zinc-800 to-zinc-950"
  : "flex items-center gap-1 h-9 px-1 rounded-full border border-white/12 bg-linear-to-br from-zinc-800 to-zinc-950";

const itemClass = compact
  ? "px-2.5 h-6"
  : "px-3 h-7";

const cookieScript =
  "document.cookie='lang-redirected=1; path=/; max-age=31536000; SameSite=Lax'";
---

<div class={containerClass}>
  <a
    href="/"
    onclick={cookieScript}
    aria-label="ES - Español"
    class={`${itemClass} rounded-full text-xs font-bold uppercase tracking-wider transition-all inline-flex items-center justify-center ${
      currentLang === "es"
        ? "bg-zinc-200 text-zinc-900"
        : "text-zinc-300 hover:text-white hover:bg-white/8"
    }`}
  >
    ES
  </a>
  <a
    href="/en/"
    onclick={cookieScript}
    aria-label="EN - English"
    class={`${itemClass} rounded-full text-xs font-bold uppercase tracking-wider transition-all inline-flex items-center justify-center ${
      currentLang === "en"
        ? "bg-zinc-200 text-zinc-900"
        : "text-zinc-300 hover:text-white hover:bg-white/8"
    }`}
  >
    EN
  </a>
</div>
