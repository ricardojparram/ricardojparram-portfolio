---
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface NavDict {
  work: string;
  about: string;
  experience: string;
  services: string;
  contact?: string;
  cta: string;
}

interface Props {
  nav: NavDict;
  lang: string;
}

const { nav, lang } = Astro.props;

const navLinks = [
  { key: "work", label: nav.work },
  { key: "about", label: nav.about },
  { key: "experience", label: nav.experience },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-500 pt-5 pb-0"
>
  <div class="px-4 md:px-7">
    <div class="max-w-6xl mx-auto overflow-visible transition-all duration-500">
      <div
        id="site-header-row"
        class="flex items-center justify-between transition-all duration-500 px-0 py-0 md:py-1.5"
      >
        <button
          id="site-logo-button"
          type="button"
          data-scroll-top
          class="flex items-center gap-2 group cursor-pointer transition-all px-0 py-0 rounded-none border border-transparent bg-transparent shadow-none"
          aria-label="Ricardo J. Parra"
        >
          <span class="text-white text-lg font-semibold tracking-tight">
            Ricardo J. Parra
          </span>
        </button>

        <nav class="hidden md:flex items-center gap-5" aria-label="Primary">
          {
            navLinks.map(({ key, label }) => (
              <a
                href={`#${key}`}
                data-nav-link
                data-section={key}
                class="relative px-0 pb-2 pt-1 text-sm font-semibold transition-colors text-zinc-400 hover:text-zinc-200 aria-[current=page]:text-white after:absolute after:left-0 after:-bottom-0.5 after:h-0.5 after:rounded-full after:bg-zinc-300 after:transition-all after:duration-300 after:w-0 after:opacity-0 aria-[current=page]:after:w-full aria-[current=page]:after:opacity-100"
              >
                {label}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-3">
          <a
            href="#contact"
            class="hidden md:flex h-9 px-5 items-center justify-center rounded-full text-white text-sm font-semibold transition-all border border-white/12 bg-linear-to-br from-zinc-800 to-zinc-950 hover:border-zinc-300/30 hover:from-zinc-700 hover:to-zinc-900"
          >
            {nav.cta}
          </a>

          <div class="hidden md:block">
            <LanguageSwitcher currentLang={lang} />
          </div>

          <button
            id="site-menu-toggle"
            type="button"
            class="md:hidden relative size-10 flex border-transparent items-center justify-center text-zinc-300 hover:text-white transition-colors rounded-full overflow-hidden"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="site-mobile-menu"
          >
            <svg
              data-menu-icon-open
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-6"
              aria-hidden="true"
            >
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="6" x2="20" y2="6"></line>
              <line x1="4" y1="18" x2="20" y2="18"></line>
            </svg>
            <svg
              data-menu-icon-close
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-6 hidden"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="site-mobile-menu" class="md:hidden mt-3 px-4 md:px-7">
    <div
      id="site-mobile-panel"
      class="max-w-6xl mx-auto rounded-2xl glass-card px-4 py-4 flex flex-col gap-2 shadow-[0_18px_50px_rgba(0,0,0,0.45)]! opacity-0 -translate-y-2 pointer-events-none max-h-0 overflow-hidden transition-all duration-300"
      style="max-height: 0;"
    >
      {
        navLinks.map(({ key, label }) => (
          <a
            href={`#${key}`}
            data-nav-link
            data-section={key}
            class="text-left px-4 py-3 rounded-xl transition-colors text-sm font-medium text-zinc-300 hover:bg-white/10 aria-[current=page]:text-white aria-[current=page]:bg-white/10"
          >
            {label}
          </a>
        ))
      }

      <div class="pt-3 border-t border-white/8 mt-2 w-full flex items-center justify-between gap-3">
        <a
          href="#contact"
          class="flex h-9 px-5 items-center justify-center rounded-full text-white text-sm font-semibold transition-all border border-white/12 bg-linear-to-br from-zinc-800 to-zinc-950 hover:border-zinc-300/30 hover:from-zinc-700 hover:to-zinc-900"
        >
          {nav.cta}
        </a>
        <LanguageSwitcher currentLang={lang} compact />
      </div>
    </div>
  </div>
</header>

<script>
  (() => {
    const sectionIds = ["work", "about", "experience"];
    const navLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]")
    );
    const topButton = document.querySelector<HTMLButtonElement>("[data-scroll-top]");
    const header = document.getElementById("site-header");
    const headerRow = document.getElementById("site-header-row");
    const logoButton = document.getElementById("site-logo-button");

    const menuToggle = document.getElementById("site-menu-toggle");
    const mobilePanel = document.getElementById("site-mobile-panel");
    const iconOpen = menuToggle?.querySelector<SVGElement>("[data-menu-icon-open]");
    const iconClose = menuToggle?.querySelector<SVGElement>("[data-menu-icon-close]");

    let menuOpen = false;

    const updateScrolledState = () => {
      const scrolled = window.scrollY > 50;

      header?.classList.toggle("is-scrolled", scrolled);
      headerRow?.classList.toggle("is-scrolled", scrolled);
      logoButton?.classList.toggle("is-scrolled", scrolled);
      menuToggle?.classList.toggle("is-scrolled", scrolled);
    };

    const setMenuState = (open: boolean) => {
      menuOpen = open;
      menuToggle?.setAttribute("aria-expanded", open ? "true" : "false");

      if (mobilePanel) {
        mobilePanel.style.opacity = open ? "1" : "0";
        mobilePanel.style.transform = open ? "translateY(0)" : "translateY(-0.5rem)";
        mobilePanel.style.pointerEvents = open ? "auto" : "none";
        mobilePanel.style.maxHeight = open ? "28rem" : "0";
      }

      iconOpen?.classList.toggle("hidden", open);
      iconClose?.classList.toggle("hidden", !open);
    };

    const updateActiveSection = () => {
      let current = sectionIds[0];
      const offset = 220;

      for (const id of sectionIds) {
        const section = document.getElementById(id);
        if (section && window.scrollY + offset >= section.offsetTop) {
          current = id;
        }
      }

      navLinks.forEach((link) => {
        const isCurrent = link.dataset.section === current;
        if (isCurrent) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    topButton?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
      setMenuState(false);
    });

    menuToggle?.addEventListener("click", () => {
      setMenuState(!menuOpen);
    });

    navLinks.forEach((link) => {
      link.addEventListener("click", () => {
        setMenuState(false);
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setMenuState(false);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768 && menuOpen) setMenuState(false);
    });

    setMenuState(false);
    updateScrolledState();
    updateActiveSection();
    window.addEventListener(
      "scroll",
      () => {
        updateScrolledState();
        updateActiveSection();
      },
      { passive: true }
    );
  })();
</script>

<style>
  #site-header.is-scrolled {
    padding-top: 0;
    padding-bottom: 0;
  }

  #site-header-row.is-scrolled {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    #site-header.is-scrolled {
      background: linear-gradient(
        180deg,
        rgba(12, 13, 15, 0.92),
        rgba(8, 9, 10, 0.92)
      );
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
    }

    #site-header-row.is-scrolled {
      padding-top: 0.625rem;
      padding-bottom: 0.625rem;
    }
  }

  #site-logo-button.is-scrolled {
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    border-color: rgba(255, 255, 255, 0.09);
    background: linear-gradient(135deg, #191b1f 0%, #101216 56%, #08090b 100%);
    box-shadow:
      0 6px 18px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      inset 0 34px 48px rgba(255, 255, 255, 0.03);
  }

  #site-menu-toggle.is-scrolled {
    background: linear-gradient(135deg, #191b1f 0%, #101216 56%, #08090b 100%);
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      inset 0 34px 48px rgba(255, 255, 255, 0.03);
  }

  @media (min-width: 768px) {
    #site-logo-button.is-scrolled {
      padding: 0;
      border-radius: 0;
      border-color: transparent;
      background: transparent;
      box-shadow: none;
    }
  }
</style>
