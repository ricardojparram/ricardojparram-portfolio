---
import type { Profile, Skill } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";
import {
  defaultSkillIcon,
  skillIconMap,
  withIcon,
} from "../../lib/icon-registry";

interface Props {
  profile: Profile;
  lang: string;
  skills: Skill[];
}

const { profile, lang, skills: sanitySkills } = Astro.props;
const t = useTranslations(lang);

// Fallback if Sanity has no skills yet
const fallbackSkills: Skill[] = [
  {
    _id: "1",
    title: t.about.skills.frontend,
    description: "NextJS, NuxtJS, Astro, Tailwind",
    iconIdentifier: "code",
  },
  {
    _id: "2",
    title: t.about.skills.design,
    description: "UI/UX, Figma, Framer",
    iconIdentifier: "palette",
  },
  {
    _id: "3",
    title: t.about.skills.backend,
    description: "NestJS, Laravel, PostgreSQL",
    iconIdentifier: "terminal",
  },
  {
    _id: "4",
    title: t.about.skills.mobile,
    description: "Expo, React Native",
    iconIdentifier: "mobile",
  },
];

const skills = sanitySkills?.length > 0 ? sanitySkills : fallbackSkills;
const skillCards = withIcon(skills, skillIconMap, defaultSkillIcon);
---

<section id="about" class="scroll-mt-28">
  <div class="mb-9">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-white">
      {t.about.title}
    </h2>
    <span class="heading-underline"></span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-center">
    <!-- Bio text from Sanity -->
    <div
      class="flex flex-col justify-center gap-3 text-zinc-300 leading-relaxed text-base"
    >
      <h3 class="text-xl md:text-2xl font-semibold text-white mb-2">
        {t.about.subtitle}
      </h3>
      {
        profile.bio?.length > 0 &&
          profile.bio.map((block: any) => (
            <p>{block.children?.map((child: any) => child.text).join("")}</p>
          ))
      }
    </div>

    <!-- Skill cards from Sanity (with fallback) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {
        skillCards.map((skill) => {
          const Icon = skill.Icon;

          return (
            <div class="glass-card rounded-3xl p-5 flex flex-col gap-3 hover:border-white/20 transition-colors duration-300 group">
              <div class="size-11 bg-primary/12 rounded-2xl border border-white/10 flex items-center justify-center group-hover:bg-primary/18 group-hover:border-white/20 group-hover:scale-105 transition-all duration-300 text-white">
                <Icon class="size-6" aria-hidden="true" />
              </div>
              <div>
                <h4 class="text-base font-semibold text-white">
                  {skill.title}
                </h4>
                <p class="text-sm text-zinc-400 mt-1">{skill.description}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
