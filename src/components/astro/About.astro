---
import type { Profile } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";

interface Props {
    profile: Profile;
    lang: string;
}

const { profile, lang } = Astro.props;
const t = useTranslations(lang);

const skills = [
    {
        icon: "code",
        title: t.about.skills.frontend,
        desc: "React, Astro, Tailwind",
    },
    {
        icon: "palette",
        title: t.about.skills.design,
        desc: "UI/UX, Figma, Glassmorphism",
    },
    {
        icon: "terminal",
        title: t.about.skills.backend,
        desc: "PHP, Node.js, MySQL",
    },
    { icon: "cpu", title: t.about.skills.mobile, desc: "Expo, React Native" },
];
---

<section id="about" class="scroll-mt-28">
    <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
            {t.about.title}
        </h2>
        <span class="heading-underline"></span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Bio text from Sanity -->
        <div
            class="flex flex-col justify-center gap-4 text-slate-300 leading-relaxed text-lg"
        >
            <h3 class="text-2xl font-bold text-white mb-2">
                {t.about.subtitle}
            </h3>
            {
                profile.bio?.length > 0 ? (
                    profile.bio.map((block: any) => (
                        <p>
                            {block.children
                                ?.map((child: any) => child.text)
                                .join("")}
                        </p>
                    ))
                ) : (
                    <>
                        <p>
                            <strong>+3 años de Experiencia.</strong> Ingeniero
                            en Informática y Desarrollador WEB especializado en
                            front-end.
                        </p>
                        <p>
                            Soy perfeccionista y apasionado a la hora de
                            sobrepasar las expectativas del cliente. Me enfoco
                            en crear aplicaciones únicas, desarrollando sistemas
                            administrativos, e-commerce, y aplicaciones móviles.
                        </p>
                        <p>
                            Busco constantemente nuevas propuestas para la
                            optimización de procesos y disfruto liderando
                            proyectos y compartiendo conocimiento con otros
                            desarrolladores.
                        </p>
                    </>
                )
            }
        </div>

        <!-- Skill cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {
                skills.map((skill) => (
                    <div class="glass-card rounded-3xl p-6 flex flex-col gap-4 hover:border-white/20 transition-colors duration-300 group">
                        <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-white/20 transition-colors text-primary">
                            {skill.icon === "code" && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="size-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                                    />
                                </svg>
                            )}
                            {skill.icon === "palette" && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="size-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
                                    />
                                </svg>
                            )}
                            {skill.icon === "terminal" && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="size-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                    />
                                </svg>
                            )}
                            {skill.icon === "cpu" && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="size-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"
                                    />
                                </svg>
                            )}
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-white">
                                {skill.title}
                            </h4>
                            <p class="text-sm text-slate-400 mt-1">
                                {skill.desc}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
