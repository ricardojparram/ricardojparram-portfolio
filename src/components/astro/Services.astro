---
import type { Service } from "../../lib/queries";
import { useTranslations } from "../../i18n/ui";
import {
  defaultServiceIcon,
  serviceIconMap,
  withIcon,
} from "../../lib/icon-registry";

interface Props {
  services: Service[];
  lang: string;
}

const { services, lang } = Astro.props;
const t = useTranslations(lang);
const serviceCards = withIcon(services, serviceIconMap, defaultServiceIcon);
---

<section id="services" class="scroll-mt-28">
  <div class="mb-9 text-center flex flex-col items-center">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-white">
      {t.services.title}
    </h2>
    <span class="heading-underline"></span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {
      serviceCards.map((service) => {
        const Icon = service.Icon;

        return (
          <div class="glass-card rounded-3xl p-6 hover:-translate-y-1 transition-all duration-300 flex flex-col gap-4 group hover:border-white/20">
            <div class="size-14 rounded-2xl flex items-center justify-center border border-white/10 group-hover:border-white/20 transition-colors icon-bg-primary text-primary">
              <Icon className="size-7" aria-hidden="true" />
            </div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">
                {service.title}
              </h3>
              <p class="text-zinc-400 leading-relaxed">{service.description}</p>
            </div>
          </div>
        );
      })
    }
  </div>
</section>
