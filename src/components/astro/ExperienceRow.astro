---
import type { Experience } from "../../lib/queries";

interface Props {
  exp: Experience;
  index: number;
  currentLabel: string;
}

const { exp, index, currentLabel } = Astro.props;
const isRightAligned = index % 2 === 1;
---

<div
  class="relative pl-5 md:pl-0 md:grid md:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] md:items-start group"
  data-reveal-item
  style={`--reveal-index: ${index + 1};`}
>
  <div
    class="absolute left-0 top-6 -translate-x-1/2 md:relative md:left-auto md:top-auto md:translate-x-0 flex items-center justify-center size-10 md:col-start-2 md:row-start-1 md:justify-self-center md:self-start md:mt-4 shrink-0 z-10 pointer-events-none"
  >
    <span
      class="absolute inset-0 rounded-full bg-zinc-500/10 blur-md opacity-80"
    ></span>
    <span
      class="relative size-2 rounded-full bg-zinc-500 shadow-[0_0_10px_rgba(113,113,122,0.18)]"
    ></span>
  </div>

  <div
    class:list={[
      "w-full md:w-full md:row-start-1 glass-card rounded-3xl p-4 md:p-5 hover:border-white/20 transition-colors",
      isRightAligned
        ? "md:col-start-3 md:justify-self-end"
        : "md:col-start-1 md:justify-self-start",
    ]}
  >
    <div class="flex flex-col gap-1 mb-2.5">
      <h3 class="text-lg md:text-xl font-semibold text-white leading-tight">
        {exp.role}
      </h3>
      <div class="flex items-center justify-between gap-2">
        <span class="text-sm font-medium text-primary-light">
          {exp.company}
        </span>
        {exp.date && <span class="text-xs text-zinc-500">{exp.date}</span>}
      </div>
    </div>
    {
      exp.active && (
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-primary/10 border border-primary/25 text-primary-light text-[11px] font-medium mb-3">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" />
          {currentLabel}
        </span>
      )
    }
    {
      exp.info?.length > 0 && (
        <ul class="flex flex-col gap-1.5 mt-1">
          {exp.info.map((block: any) => {
            const text = block.children?.map((c: any) => c.text).join("");
            return text ? (
              <li class="flex items-start gap-2 text-sm text-zinc-400 leading-relaxed">
                <span class="mt-1.5 size-1.5 rounded-full bg-primary shrink-0" />
                {text}
              </li>
            ) : null;
          })}
        </ul>
      )
    }
  </div>
</div>
