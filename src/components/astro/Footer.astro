---
// Footer.astro - Fully static, no Sanity data needed
import { commonIconMap } from "../../lib/icon-registry";
---

<footer class="footer-glass border-t border-white/5 mt-auto relative z-10">
  <div
    class="max-w-300 mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-8"
  >
    <!-- Brand -->
    <div class="flex flex-col gap-2 items-center md:items-start">
      <div class="flex items-center gap-2 text-white font-bold text-lg">
        <commonIconMap.code
          className="size-6 text-primary"
          aria-hidden="true"
        />
        ricardojparram
      </div>
      <p class="text-zinc-500 text-sm">
        © {new Date().getFullYear()} Ricardo Parra. All rights reserved.
      </p>
    </div>

    <!-- Social -->
    <div class="flex items-center gap-6">
      <a
        href="https://github.com/ricardojparram"
        target="_blank"
        rel="noreferrer"
        class="text-zinc-400 hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <commonIconMap.github className="size-5" aria-hidden="true" />
      </a>
      <a
        href="https://linkedin.com/in/ricardojparram/"
        target="_blank"
        rel="noreferrer"
        class="text-zinc-400 hover:text-white transition-colors"
        aria-label="LinkedIn"
      >
        <commonIconMap.linkedin className="size-5" aria-hidden="true" />
      </a>
    </div>
  </div>
</footer>
